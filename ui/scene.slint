import { Slider, GroupBox, HorizontalBox, VerticalBox, GridBox, Button, ComboBox, Palette } from "std-widgets.slint";

export component App inherits Window {
    in property <image> texture <=> plot-image.source;
    out property <int> requested-texture-width: plot-image.width / 1phx;
    out property <int> requested-texture-height: plot-image.height / 1phx;

    out property <float> amplitude <=> amp-slider.value;
    out property <float> frequency <=> freq-slider.value;
    out property <float> x-zoom <=> zoom-slider.value;
    in-out property <bool> paused: false;
    out property <bool> dark-mode: Palette.color-scheme == ColorScheme.dark;

    in property <string> status-text: "Initializing...";

    property <bool> is-dark: Palette.color-scheme == ColorScheme.dark;
    property <color> plot-bg: is-dark ? #0f0f1e : #ffffff;
    property <color> grid-color: is-dark ? #1a1a30 : #e0e0e0;
    property <color> axis-color: is-dark ? #5555aa : #808080;
    property <length> label-width: 45px;

    preferred-width: 900px;
    preferred-height: 650px;
    title: "3-Phase Motor Current - Real-Time Plot";

    VerticalBox {
        x: root.safe-area-insets.left;
        y: root.safe-area-insets.top;
        width: root.width - root.safe-area-insets.right - root.safe-area-insets.left;
        height: root.height - root.safe-area-insets.bottom - root.safe-area-insets.top;

        Text {
            text: "3-Phase Motor Current Waveform";
            font-size: 16px;
            horizontal-alignment: center;
        }

        Rectangle {
            preferred-width: 800px;
            preferred-height: 480px;
            min-width: 320px;
            min-height: 200px;

            // Y-axis labels
            for label[i] in ["15", "10", "5", "0", "-5", "-10", "-15"]: Text {
                x: 0;
                y: i * (plot-area.height / 6) + plot-area.y - self.height / 2;
                width: root.label-width - 4px;
                horizontal-alignment: right;
                text: label;
                font-size: 11px;
                color: root.axis-color;
            }

            // Plot area with grid
            plot-area := Rectangle {
                x: root.label-width;
                y: 0;
                width: parent.width - root.label-width;
                height: parent.height;
                background: root.plot-bg;
                border-width: 1px;
                border-color: root.axis-color;

                // Vertical grid lines (10 divisions, 9 interior lines)
                for i in 9: Rectangle {
                    x: (i + 1) * (parent.width / 10);
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: root.grid-color;
                }

                // Horizontal grid lines (6 divisions, 5 interior lines)
                for i in 5: Rectangle {
                    x: 0;
                    y: (i + 1) * (parent.height / 6);
                    width: parent.width;
                    height: 1px;
                    background: root.grid-color;
                }

                // Zero line (center, slightly thicker)
                Rectangle {
                    x: 0;
                    y: parent.height / 2 - 0.5px;
                    width: parent.width;
                    height: 1.5px;
                    background: root.axis-color;
                }

                // Waveform texture overlay (transparent background)
                plot-image := Image {
                    width: parent.width;
                    height: parent.height;
                }
            }
        }

        HorizontalBox {
            Text {
                text: root.status-text;
                vertical-alignment: center;
            }
        }

        GroupBox {
            title: "Controls";
            GridBox {
                Row {
                    Text { text: "Amplitude (A):"; vertical-alignment: center; }
                    amp-slider := Slider { minimum: 0.1; maximum: 10.0; value: 5.0; }
                }
                Row {
                    Text { text: "Frequency (Hz):"; vertical-alignment: center; }
                    freq-slider := Slider { minimum: 1.0; maximum: 20.0; value: 5.0; }
                }
                Row {
                    Text { text: "X Zoom:"; vertical-alignment: center; }
                    zoom-slider := Slider { minimum: 0.05; maximum: 1.0; value: 1.0; }
                }
                Row {
                    Text { text: "Theme:"; vertical-alignment: center; }
                    theme-combo := ComboBox {
                        model: ["System", "Dark", "Light"];
                        current-index: 0;
                        selected => {
                            if (self.current-index == 0) {
                                Palette.color-scheme = ColorScheme.unknown;
                            } else if (self.current-index == 1) {
                                Palette.color-scheme = ColorScheme.dark;
                            } else {
                                Palette.color-scheme = ColorScheme.light;
                            }
                        }
                    }
                }
                Row {
                    Button {
                        text: root.paused ? "Resume" : "Pause";
                        clicked => { root.paused = !root.paused; }
                    }
                }
            }
        }
    }
}
