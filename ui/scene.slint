import { Slider, GroupBox, HorizontalBox, VerticalBox, GridBox, Button, ComboBox, Palette } from "std-widgets.slint";

export component App inherits Window {
    in property <image> texture <=> plot-image.source;
    out property <int> requested-texture-width: plot-image.width / 1phx;
    out property <int> requested-texture-height: plot-image.height / 1phx;

    out property <float> amplitude <=> amp-slider.value;
    out property <float> frequency <=> freq-slider.value;
    out property <float> x-zoom <=> zoom-slider.value;
    in-out property <bool> paused: false;
    out property <bool> dark-mode: Palette.color-scheme == ColorScheme.dark;

    in property <string> status-text: "Initializing...";

    preferred-width: 900px;
    preferred-height: 650px;
    title: "3-Phase Motor Current - Real-Time Plot";

    VerticalBox {
        Text {
            text: "3-Phase Motor Current Waveform";
            font-size: 16px;
            horizontal-alignment: center;
        }

        plot-image := Image {
            preferred-width: 800px;
            preferred-height: 480px;
            min-width: 320px;
            min-height: 200px;
            width: 100%;
        }

        HorizontalBox {
            Text {
                text: root.status-text;
                vertical-alignment: center;
            }
        }

        GroupBox {
            title: "Controls";
            GridBox {
                Row {
                    Text { text: "Amplitude (A):"; vertical-alignment: center; }
                    amp-slider := Slider { minimum: 0.1; maximum: 10.0; value: 5.0; }
                }
                Row {
                    Text { text: "Frequency (Hz):"; vertical-alignment: center; }
                    freq-slider := Slider { minimum: 1.0; maximum: 20.0; value: 5.0; }
                }
                Row {
                    Text { text: "X Zoom:"; vertical-alignment: center; }
                    zoom-slider := Slider { minimum: 0.05; maximum: 1.0; value: 1.0; }
                }
                Row {
                    Text { text: "Theme:"; vertical-alignment: center; }
                    theme-combo := ComboBox {
                        model: ["System", "Dark", "Light"];
                        current-index: 0;
                        selected => {
                            if (self.current-index == 0) {
                                Palette.color-scheme = ColorScheme.unknown;
                            } else if (self.current-index == 1) {
                                Palette.color-scheme = ColorScheme.dark;
                            } else {
                                Palette.color-scheme = ColorScheme.light;
                            }
                        }
                    }
                }
                Row {
                    Button {
                        text: root.paused ? "Resume" : "Pause";
                        clicked => { root.paused = !root.paused; }
                    }
                }
            }
        }
    }
}
